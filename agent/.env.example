# URL of the hosted Meta Audit app (local dev: http://localhost:3311, or your Vercel URL).
API_BASE_URL=""

# Must match AGENT_TOKEN in the hosted app's .env.
AGENT_TOKEN=""

# Full path to the Screaming Frog CLI executable. Use forward slashes even on
# Windows — dotenv treats backslash sequences like \n as escape codes inside
# quoted values, which silently corrupts a Windows path written with them.
# e.g. "C:/Program Files (x86)/Screaming Frog SEO Spider/ScreamingFrogSEOSpiderCli.exe"
SF_CLI_PATH=""

# Optional: path to a saved .seospiderconfig file (forward slashes, see note above).
# Leave blank to use SF's default settings.
SF_CONFIG_PATH=""

# Optional: how often to poll for queued crawl jobs, in ms. Defaults to 15000.
POLL_INTERVAL_MS=15000
