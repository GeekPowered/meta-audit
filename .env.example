# Postgres connection string (Neon recommended for Vercel serverless — pooled connection).
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Shared password for the dashboard's HTTP Basic Auth gate (see proxy.ts).
BASIC_AUTH_PASSWORD=""

# Bearer token the local Screaming Frog agent (Phase 2) uses to authenticate
# against /api/agent/* instead of the dashboard's Basic Auth.
AGENT_TOKEN=""

# Claude API key, used to generate rewrite suggestions (Phase 4).
ANTHROPIC_API_KEY=""

# Model used for suggestion generation. Chosen for cost/quality balance at
# volume (30-40 clients, hundreds of pages each) over the highest-tier default.
SUGGESTION_MODEL="claude-sonnet-4-6"

# Webflow Site/Workspace API token (Phase 6) — one token covers every client
# site since they all live in the same GPS Webflow workspace.
WEBFLOW_API_TOKEN=""

# Added in later phases:
# GSC_SERVICE_ACCOUNT_JSON=""
